# Postiz 专属环境变量（独立于 Brand Agent 的 .env）
#
# 使用方式：
#   1. 复制本文件为 .env.postiz
#   2. 生成一个强随机 JWT_SECRET：
#      python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#   3. 粘贴到 JWT_SECRET=
#
# 社交平台 API 凭证按需启用，不填则该平台无法在 Postiz UI 中绑定。
# 绝大部分平台走 OAuth，只需在 Postiz UI 里点「Add Channel」跳转授权即可。
# 但 X/Twitter 必须在开发者后台申请 App 才能拿到 X_API_KEY + X_API_SECRET。

# === 核心安全配置（必填）===
JWT_SECRET=请替换为强随机字符串不要直接使用这句话

# === X/Twitter（必填才能绑定 X 账号）===
# 申请地址：https://developer.twitter.com/
# 创建 App 后在 Keys and Tokens 页获取
X_API_KEY=
X_API_SECRET=

# === LinkedIn ===
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# === Reddit ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# === Mastodon（实例 URL 可改为你自己的）===
MASTODON_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=

# === Threads（Meta 开发者平台）===
THREADS_APP_ID=
THREADS_APP_SECRET=

# === Facebook（Meta 开发者平台）===
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# === YouTube（Google Cloud Console）===
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# === TikTok ===
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# === Pinterest ===
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# === GitHub（Postiz 可发 GitHub Release Notes）===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === Discord（需要 Bot Token）===
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN_ID=

# === Slack ===
SLACK_ID=
SLACK_SECRET=
SLACK_SIGNING_SECRET=
