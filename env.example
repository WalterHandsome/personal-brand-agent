# LLM 后端配置（至少配一个，优先级：Bedrock > Anthropic > OpenAI）

# 方案 1：AWS Bedrock（推荐，走 AWS 通道更稳定）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# 方案 2：Anthropic 直连 API
ANTHROPIC_API_KEY=

# 方案 3：OpenAI（成本最低）
OPENAI_API_KEY=

# 默认模型（用于 Anthropic 直连）
DEFAULT_MODEL=claude-sonnet-4-20250514

# 知识库配置
CHROMA_PERSIST_DIR=./data/chroma_db
NOTES_DIR=./data/notes

# 平台 API（按需配置）
GITHUB_TOKEN=ghp_xxx
JUEJIN_COOKIE=
TWITTER_BEARER_TOKEN=
ZHIHU_COOKIE=

# 博客配置
BLOG_REPO=WalterHandsome/WalterHandsome.github.io
BLOG_FILE=blog.html

# 推送配置（Bark - iOS 推送通知）
# 下载 Bark App → 打开 → 复制推送地址
BARK_URL=https://api.day.app/你的key

# Postiz 配置（多平台分发）
# 本地 Docker 启动 Postiz 后填写
POSTIZ_URL=http://localhost:5000
POSTIZ_API_KEY=你的postiz-api-key
